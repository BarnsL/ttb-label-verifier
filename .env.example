# ─── Required ──────────────────────────────────────────────────────────────────
# Your Anthropic API key. Get one at console.anthropic.com.
# This key is used server-side only — it is never sent to the browser.
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Optional: Model selection ─────────────────────────────────────────────────
# Controls which Claude vision model reads label images. Trade accuracy vs. speed.
#
#   claude-haiku-4-5    → Fastest / cheapest. Accurate on clean, flat labels.
#                         May miss fine details on degraded or angled photos.
#
#   claude-sonnet-4-6   → DEFAULT. Accurate on real-world phone photos (glare,
#                         angle, low light) while staying inside the 5-second SLA.
#
#   claude-opus-4-8     → Highest accuracy on difficult images. Slightly slower
#                         (~5s), higher cost per call.
#
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Optional: /grade email endpoint ───────────────────────────────────────────
# Required only if you want the reviewer scorecard (/grade) to send email.
# Create a free account at resend.com, then generate an API key.
# Without these variables, /grade still loads but returns an error on submit.
RESEND_API_KEY=re_...

# Email address that receives /grade scorecard submissions.
GRADE_EMAIL_TO=you@example.com

# Sender address (must be a verified Resend sending domain).
# The default uses Resend's shared sandbox sender — fine for testing.
# GRADE_EMAIL_FROM=TTB Label Verifier <noreply@yourdomain.com>
