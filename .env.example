# Required: your Anthropic API key (used server-side for label extraction).
ANTHROPIC_API_KEY=

# Optional: choose the vision model. Default is claude-sonnet-4-6 (fast + accurate,
# meets the 5-second target). Alternatives:
#   claude-opus-4-8    — most accurate on poor images (~5s)
#   claude-haiku-4-5   — fastest, lowest cost
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: Resend email for the in-app grading rubric (/grade). Without these,
# /grade still loads but returns a "not configured" message on submit.
RESEND_API_KEY=
GRADE_EMAIL_TO=you@example.com
# GRADE_EMAIL_FROM=TTB Label Verifier <onboarding@resend.dev>
