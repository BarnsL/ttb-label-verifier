# Required: your Anthropic API key (used server-side for label extraction).
ANTHROPIC_API_KEY=

# Optional: choose the vision model. Default is claude-opus-4-8 (most accurate).
# For the TTB 5-second target, switch to a faster model:
#   claude-haiku-4-5    — fastest, lowest cost
#   claude-sonnet-4-6   — balanced
# ANTHROPIC_MODEL=claude-opus-4-8
